# update.0err.com - Firewall Allowlist Gateway
# Copy this to .env and fill in the values

# PostgreSQL
POSTGRES_PASSWORD=your-strong-postgres-password

# Redis
REDIS_PASSWORD=your-strong-redis-password

# Session JWT signing key (32+ hex chars)
SESSION_SECRET=your-64-char-hex-session-secret

# HMAC signing key for agent payloads (32+ hex chars)
APP_SIGNING_SECRET=your-64-char-hex-signing-secret

# Admin email (OTP login + registration)
ADMIN_EMAIL=admin@example.com

# SMTP for sending OTP codes
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@example.com

# Agent bearer token (prefix agt_ + 48 hex chars)
AGENT_TOKEN=agt_your-generated-agent-token

# Cloudflare Access (optional)
# CF_TEAM_DOMAIN=yourteam
# CF_AUD=your-audience-tag
