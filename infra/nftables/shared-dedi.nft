table inet shared_dedi {
  set db_allow_v4 {
    type ipv4_addr
    flags interval, timeout
  }

  set db_allow_v6 {
    type ipv6_addr
    flags interval, timeout
  }

  chain input {
    type filter hook input priority -200; policy accept;

    ct state established,related accept
    iif lo accept

    tcp dport {15432, 27017, 19000, 50000-60000} ip saddr != @db_allow_v4 drop
    tcp dport {15432, 27017, 19000, 50000-60000} ip6 saddr != @db_allow_v6 drop
  }
}
